# Chiave per generare i riassunti AI (opzionale).
# Senza chiave, lo script usa l'estratto del feed RSS come fallback.

# --- Generazione sintesi AI (opzionale) ---
# Imposta UNA di queste chiavi. Senza nessuna, il sito mostra solo titolo + link.
# Groq (consigliato): modelli open-source gratuiti — https://console.groq.com
GROQ_API_KEY=
# In alternativa Anthropic (Claude Haiku, a pagamento):
ANTHROPIC_API_KEY=
# Modello (facoltativo): default Groq "llama-3.3-70b-versatile",
# default Anthropic "claude-haiku-4-5-20251001".
SUMMARY_MODEL=
# Modello dedicato SOLO al raggruppamento delle notizie (facoltativo): se vuoi
# usare un modello più potente solo per quel passaggio, es. "openai/gpt-oss-120b"
# o "qwen/qwen3.6-27b". Se vuoto, usa SUMMARY_MODEL/default.
GROUPING_MODEL=

# --- Raccolta automatica (deploy) ---
# Token segreto per proteggere la rotta /api/collect chiamata dallo scheduler.
# Genera una stringa casuale lunga, es: openssl rand -hex 24
COLLECT_SECRET=

# --- Sito ---
# URL pubblico del sito (per sitemap, Open Graph, dati strutturati).
NEXT_PUBLIC_SITE_URL=https://lazio24.news

# --- Notifiche push (Web Push / VAPID) ---
# Genera le chiavi una volta con:  npx web-push generate-vapid-keys
# La pubblica viene servita al client da /api/push/key; la privata firma gli invii.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contatto del mittente (richiesto dallo standard VAPID).
VAPID_SUBJECT=mailto:legal@lazio24.news

# --- Donazioni / membership ---
# Link al tuo profilo (Buy Me a Coffee, Ko-fi, PayPal.me, Stripe…).
# Deve avere il prefisso NEXT_PUBLIC_ per essere usato nel frontend.
NEXT_PUBLIC_SUPPORT_URL=https://www.paypal.me/frankcecca

# --- Analytics (Umami, cookieless e anonimo) ---
# Statistiche di visita senza cookie e senza dati personali: nessun banner.
# Lo script viene caricato solo se ENTRAMBE le variabili sono impostate.
# URL completo dello script della tua istanza Umami self-hosted.
NEXT_PUBLIC_UMAMI_SRC=
# ID del sito generato nella dashboard Umami.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
