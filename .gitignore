.DS_Store

# Immagini e favicon generate dalla raccolta (rigenerate sul server)
public/images/*
!public/images/.gitkeep
public/sources/*
!public/sources/.gitkeep

# Favicon delle fonti generate a runtime (vivono sul volume persistente data/)
data/sources/
# Cache delle sintesi AI (vive sul volume persistente)
data/summaries.json
# Dati raccolti (vivono sul volume persistente, non vanno committati come "seme")
data/articles.json
# Iscrizioni alle notifiche push e stato dedupe (dati utente, sul volume)
data/push-subscriptions.json
data/push-state.json
